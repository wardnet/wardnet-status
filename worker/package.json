{
  "name": "@wardnet/status-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply wardnet-status --local",
    "migrate:remote": "wrangler d1 migrations apply wardnet-status --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "~5.7.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.22.0"
  },
  "dependencies": {
    "yaml": "^2.8.0",
    "zod": "^3.25.67"
  }
}
